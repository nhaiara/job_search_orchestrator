# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GOOGLE_DRIVE_FOLDER_ID: The ID of the folder to monitor for .md files.
GOOGLE_DRIVE_FOLDER_ID="MY_FOLDER_ID"

# GOOGLE_SERVICE_ACCOUNT_EMAIL: The email of the service account.
GOOGLE_SERVICE_ACCOUNT_EMAIL="my-service-account@project.iam.gserviceaccount.com"

# GOOGLE_PRIVATE_KEY: The private key of the service account (replace \n with actual newlines).
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# GOOGLE_CLIENT_ID: For Google OAuth (to use personal account storage)
GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET: For Google OAuth
GOOGLE_CLIENT_SECRET=""
