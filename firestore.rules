rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: /users/{userId}
    // Document ID: userId (UID)
    // Fields:
    //   - uid: string (required)
    //   - name: string
    //   - email: string
    //   - masterProfile: string (required)
    //   - cvTemplate: string
    //   - clTemplate: string
    //   - updatedAt: timestamp
    //
    // Collection: /users/{userId}/applications/{applicationId}
    // Document ID: auto-generated
    // Fields:
    //   - id: string
    //   - uid: string (required)
    //   - company: string (required)
    //   - role: string (required)
    //   - status: string (required, enum)
    //   - matchScore: string (enum)
    //   - gapAnalysis: string
    //   ...
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'masterProfile']) &&
             data.uid is string &&
             data.masterProfile is string &&
             data.masterProfile.size() < 50000;
    }

    function isValidApplication(data) {
      return data.keys().hasAll(['uid', 'company', 'role', 'status']) &&
             data.uid is string &&
             data.company is string &&
             data.role is string &&
             data.status is string &&
             data.company.size() < 200 &&
             data.role.size() < 200;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUserProfile(request.resource.data);
      allow update: if isOwner(userId) && isValidUserProfile(request.resource.data);

      match /applications/{applicationId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidApplication(request.resource.data);
        allow update: if isOwner(userId) && isValidApplication(request.resource.data);
        allow delete: if isOwner(userId);
      }
    }
  }
}
